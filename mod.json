{
    "geode": "5.6.1",
    "gd": {
        "win": "2.2081"
    },
    "id": "axiom.voicecontrol",
    "name": "Voice Control",
    "version": "v1.2.1",
    "developer": "Axiom",
    "description": "jump with your voice. clap, yell, breathe too loud, whatever if its loud enough, you jump",
    "tags": ["joke", "gameplay"],
    "settings": {
        "enabled": {
            "name": "Enabled",
            "description": "Toggle the mod on/off",
            "type": "bool",
            "default": true
        },
        "threshold-db": {
            "name": "Trigger Threshold (dB)",
            "description": "How loud your mic needs to be to trigger a click. Lower = more sensitive. -30 is the best imo",
            "type": "float",
            "default": -30.0,
            "min": -60.0,
            "max": 0.0,
            "control": {
                "slider": true,
                "arrows": true,
                "arrow-step": 1.0,
                "input": true
            }
        }
    },
    "dependencies": {
        "geode.node-ids": {
            "version": ">=v1.0.0",
            "importance": "required"
        }
    },
    "links": {
        "github": "https://github.com/axiom-S25u/Voice-Control",
        "community": "https://discord.gg/TWn99qzmUA"
    }
}
